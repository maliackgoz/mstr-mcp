# =====================================================================
# MicroStrategy MCP Server Configuration Template
# Copy this file to '.env' and fill in your actual details.
# =====================================================================

# --- MicroStrategy Library API Configuration ---
MSTR_BASE_URL=https://mstr-library.internal-bank.com/MicroStrategyLibrary/api
MSTR_PROJECT_ID=YOUR_PROJECT_ID
MSTR_SSL_VERIFY=True

# --- FastMCP Server Execution Configuration ---
MSTR_MCP_TRANSPORT=sse
MSTR_MCP_HOST=0.0.0.0
MSTR_MCP_PORT=8000
COMPLIANCE_LOG_PATH=/app/logs/mstr_mcp_compliance.log

# --- Proxy Settings (Only if required to reach MSTR or PyPI) ---
# HTTP_PROXY=http://your-proxy-ip-or-domain:8080
# HTTPS_PROXY=http://your-proxy-ip-or-domain:8080
# NO_PROXY=localhost,127.0.0.1,.yourcompany.com


# =====================================================================
# Integration Testing Configuration
# Used ONLY when running integration tests (test/test_integration.py)
# =====================================================================
MSTR_USERNAME=your_ldap_username
MSTR_PASSWORD=your_ldap_password
MSTR_TEST_DOCUMENT_ID=optional_document_id_for_testing
RECIPIENT_EMAIL=your_test_email@example.com

